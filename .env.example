# ── Gemini (Script Generation) ──────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Kling AI (Primary Video Generator) ──────────────────────────────────────
KLING_ACCESS_KEY=your_kling_access_key_here
KLING_SECRET_KEY=your_kling_secret_key_here

# ── Pika Labs (Fallback 1) ───────────────────────────────────────────────────
PIKA_API_KEY=your_pika_api_key_here

# ── Hailuo AI / MiniMax (Fallback 2) ────────────────────────────────────────
HAILUO_API_KEY=your_hailuo_api_key_here
HAILUO_GROUP_ID=your_hailuo_group_id_here

# ── Runway ML (Fallback 3) ───────────────────────────────────────────────────
RUNWAY_API_KEY=your_runway_api_key_here

# ── YouTube Data API ─────────────────────────────────────────────────────────
YOUTUBE_CLIENT_SECRETS_PATH=client_secrets.json

# ── Channel Settings ─────────────────────────────────────────────────────────
CHANNEL_NICHE=cute baby daily activities
MADE_FOR_KIDS=true
